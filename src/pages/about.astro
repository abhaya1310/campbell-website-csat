---
import Base from '../layouts/Base.astro';
---
<Base title="About | Campbell India">
<div class="film-grain"></div>

<main class="w-full">
<!-- SECTION 1: HERO -->
<section class="relative w-full h-[100vh] min-h-[760px] flex items-center justify-center overflow-hidden">
<div class="absolute inset-0 z-0">
<div class="w-full h-full bg-cover bg-center" style="background-image: url('/images/atmosphere.jpg');"></div>
<div class="absolute inset-0 bg-background/65"></div>
<div class="dark-luxe-vignette"></div>
</div>
<div class="relative z-10 text-center px-gutter max-w-container-max mx-auto mt-24">
<div class="flex items-center justify-center gap-4 mb-8">
<div class="h-px w-12 bg-secondary"></div>
<span class="font-label-caps text-label-caps text-secondary tracking-[0.2em] uppercase">Since 2019</span>
<div class="h-px w-12 bg-secondary"></div>
</div>
<h1 class="font-display-lg-mobile md:font-display-lg text-primary mb-8 md:mb-12">
                A passion for<br class="hidden md:block"/> unforgettable hospitality
            </h1>
<p class="font-body-lg text-on-surface/80 max-w-2xl mx-auto font-light">
                Operating at the forefront of India's evolving luxury hospitality landscape — from Michelin-style cuisine to world-renowned nightlife.
            </p>
</div>
</section>

<!-- SECTION 2: BACKGROUND -->
<section class="py-section-padding-mobile md:py-section-padding px-gutter max-w-container-max mx-auto">
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
<div class="md:col-span-5 md:col-start-1 mb-12 md:mb-0">
<div class="flex items-center gap-4 mb-12">
<span class="font-label-caps text-label-caps text-secondary tracking-[0.2em] uppercase">— Background</span>
</div>
<h2 class="font-headline-lg-mobile md:font-headline-lg text-primary mb-8 leading-tight">
                    Built at the intersection of dining, lifestyle and entertainment.
                </h2>
<div class="font-body-md text-on-surface/80 space-y-6 font-light leading-relaxed">
<p>
                        Founded with a passion for creating unforgettable hospitality experiences, our brand portfolio includes Cosy Box, Ophelia, Toy Room, Meette, Louve and the Royal House of Patiala — each uniquely positioned at the intersection of fine dining, lifestyle and entertainment.
                    </p>
<p>
                        From Michelin-style cuisine to world-renowned nightlife, our presence in major cities like Delhi, Mumbai, Kolkata and Pune reflects a deep understanding of urban tastes and a commitment to delivering elevated, culturally resonant experiences.
                    </p>
</div>
</div>
<div class="md:col-span-6 md:col-start-7 relative aspect-[4/5] md:aspect-auto md:h-[760px] w-full">
<div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/gallery-cosybox.jpg');"></div>
<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-80"></div>
</div>
</div>
</section>

<!-- SECTION 3: VISION -->
<section class="py-section-padding bg-surface-container-lowest border-y border-secondary/10">
<div class="max-w-4xl mx-auto px-gutter text-center">
<span class="font-label-caps text-label-caps text-secondary mb-8 block tracking-[0.2em] uppercase">— Our Vision</span>
<p class="font-headline-lg-mobile md:font-headline-lg text-primary leading-snug mb-8">
                To redefine luxury hospitality by curating immersive dining and nightlife experiences that seamlessly blend global sophistication with Indian warmth.
            </p>
<p class="font-body-lg text-on-surface-variant max-w-2xl mx-auto font-light">
                Through our distinguished brands, we aspire to set new benchmarks in culinary excellence, ambiance and guest delight.
            </p>
</div>
</section>

<!-- SECTION 4: FOUNDERS -->
<section class="py-section-padding-mobile md:py-section-padding px-gutter max-w-container-max mx-auto">
<div class="text-center mb-16 md:mb-24">
<span class="font-label-caps text-label-caps text-secondary mb-4 block tracking-[0.2em] uppercase">— Leadership</span>
<h2 class="font-headline-lg text-headline-lg text-primary">The Founders</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-gutter items-center mb-20 md:mb-28">
<div class="md:col-span-6 relative aspect-[5/6] w-full overflow-hidden luxe-shadow img-vignette bg-surface-container">
<img alt="Shikha and Ashish Begwani" class="w-full h-full object-cover" src="/images/founders.jpg"/>
</div>
<div class="md:col-span-6 space-y-12">
<div>
<h3 class="font-headline-md text-headline-md text-primary mb-1">Ashish Begwani</h3>
<p class="font-label-caps text-[11px] text-secondary tracking-[0.18em] uppercase mb-5">Founder</p>
<p class="font-body-md text-on-surface/80 font-light leading-relaxed">
                        A seasoned entrepreneur and investor with over two decades of experience across real estate, finance and international business. He holds leadership roles in multiple companies in India and the UK, including Campbell Advertising, Compass Tracom and Campbell Property &amp; Hospitality Ltd. Known for his strategic vision and hands-on approach, Ashish has driven business growth across diversified portfolios and cross-border ventures.
                    </p>
</div>
<div>
<h3 class="font-headline-md text-headline-md text-primary mb-1">Shikha Begwani</h3>
<p class="font-label-caps text-[11px] text-secondary tracking-[0.18em] uppercase mb-5">Co-Founder</p>
<p class="font-body-md text-on-surface/80 font-light leading-relaxed">
                        A serial entrepreneur and investor with ventures across hospitality, luxury lifestyle and finance. The force behind leading brands like Cosy Box, Ophelia and Toy Room in India, she has brought global concepts such as Cannes' official dining partner to the Indian market. Combining creative vision with strategic acumen, Shikha is recognised among LuxeBook's Top 50 Powerful Women in Luxury.
                    </p>
</div>
</div>
</div>

<div class="text-center">
<a class="solid-button inline-flex px-10 py-4 font-button text-button uppercase tracking-widest" href="/brands">
                Discover Our Brands
            </a>
</div>
</section>
</main>
</Base>
